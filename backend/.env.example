# --- RENDER BACKEND SETTINGS ---
DEBUG=False
SECRET_KEY=generate-a-new-one-for-production
ALLOWED_HOSTS=sareeshala-backend.onrender.com,localhost

# --- DATABASE (From Phase 2: PostgreSQL) ---
# Use the "Internal Database URL" from Render
DATABASE_URL=postgres://user:password@internal-host:5432/sareeshala

# --- REDIS (From Phase 3: Key Value) ---
# Use the "Internal Connection String" from Render
REDIS_URL=redis://your-internal-redis-host:6379

# --- EMAIL ---
EMAIL_HOST_PASSWORD=your-gmail-app-password

# --- CORS (Your Frontend URL) ---
CORS_ALLOWED_ORIGINS=https://sareeshala-frontend.onrender.com
CORS_ALLOW_ALL_ORIGINS=False
